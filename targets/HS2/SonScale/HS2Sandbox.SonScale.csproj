<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>HS2Sandbox.SonScale</AssemblyName>
    <RootNamespace>HS2SandboxPlugin</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="$(SrcRoot)Core\**\*.cs" />
    <Compile Include="$(SrcRoot)SonScale\**\*.cs" />
    <Compile Include="Plugin.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="$(AssetsRoot)sonscale-icon.png" CopyToOutputDirectory="Always" Link="sonscale-icon.png" />
    <EmbeddedResource Include="$(AssetsRoot)sonscale-icon.png">
      <LogicalName>$(AssemblyName).sonscale-icon.png</LogicalName>
      <Link>sonscale-icon.png</Link>
    </EmbeddedResource>
  </ItemGroup>
</Project>
