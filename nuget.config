<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="BepInEx" value="https://nuget.bepinex.dev/v3/index.json" />
    <add key="IllusionLibs" value="https://pkgs.dev.azure.com/IllusionMods/Nuget/_packaging/IllusionMods/nuget/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="Microsoft.*" />
      <package pattern="System.*" />
      <package pattern="MonoMod.*" />
      <package pattern="HarmonyX" />
      <package pattern="hidlibrary" />
      <package pattern="DynamicLanguageRuntime" />
      <package pattern="IronPython" />
      <package pattern="Ionic.*" />
      <package pattern="SQLitePCLRaw*" />
      <package pattern="Mono.Cecil" />
    </packageSource>
    <packageSource key="IllusionLibs">
      <package pattern="IllusionLibs.*" />
      <package pattern="IllusionModdingAPI.*" />
      <package pattern="ExtensibleSaveFormat.*" />
      <package pattern="KoikatuCompatibilityAnalyzer" />
    </packageSource>
    <packageSource key="BepInEx">
      <package pattern="BepInEx.*" />
      <package pattern="BepInEx.PluginInfoProps" />
      <package pattern="UnityEngine.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
