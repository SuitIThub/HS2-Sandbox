<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Prevent SDK default globs from pulling in Modules/**/obj generated files -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="HS2SandboxPlugin.cs" />
    <Compile Include="SearchBarManager\MultiPathSearchBarManager.cs" />

    <Compile Include="Shared\**\*.cs" />
    <Compile Include="SubWindows\**\*.cs" />
    <Compile Include="Timeline\**\*.cs" />
    <Compile Include="CopyScript\**\*.cs" />
    <Compile Include="Notebook\**\*.cs" />
    <Compile Include="SonScale\**\*.cs" />
    <Compile Include="WorkspaceTreeLock\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="copy-icon.png" CopyToOutputDirectory="Always" />
    <Content Include="timeline-icon.png" CopyToOutputDirectory="Always" />
    <Content Include="sonscale-icon.png" CopyToOutputDirectory="Always" />
    <Content Include="notes-icon.png" CopyToOutputDirectory="Always" />
    <EmbeddedResource Include="sonscale-icon.png">
      <LogicalName>$(AssemblyName).sonscale-icon.png</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="notes-icon.png">
      <LogicalName>$(AssemblyName).notes-icon.png</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>

