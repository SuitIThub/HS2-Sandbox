<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Prevent SDK default globs from pulling in Modules/**/obj generated files -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="HS2SandboxPlugin.cs" />
    <Compile Include="SearchBarManager\MultiPathSearchBarManager.cs" />

    <Compile Include="Shared\**\*.cs" />
    <Compile Include="SubWindows\**\*.cs" />
    <Compile Include="Timeline\**\*.cs" />
    <Compile Include="CopyScript\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="copy-icon.png" CopyToOutputDirectory="Always" />
    <Content Include="timeline-icon.png" CopyToOutputDirectory="Always" />
  </ItemGroup>

</Project>

